## Diperkenalkan fitur device mode sejak ROS 7  
# Device-mode=basic, home, advanced
# saat di print kita bisa lihat daftar 
/system/device-mode print
/system/device-mode update romon=yes
/system/device-mode update mode=advanced
/system/device-mode update mode=advanced romon=yes

## IDENTITAS
/system identity set name=5009-CORE-BanggaiLaut

# -------------------------------------- #
# NTP
/system ntp client 
set enabled=yes
# servers add address=pool.ntp.org
servers add address=0.id.pool.ntp.org
servers add address=1.id.pool.ntp.org

# test 
/system clock print
/system ntp client print

# -------------------------------------- #
## LINK KE ACCESS (RB5009)
/ip address
add address=200.200.200.1/29 interface=ether1 comment="PtP sementara /29 ke RB5009 ACCESS"
# add address=200.200.200.1/30 interface=sfp-sfpplus1 comment="PtP ke RB5009 (direct SFP+, aktifkan saat ready)"

## ROUTE BALIK KE LAN (WAJIB, AGAR ASIMETRI TIDAK TERJADI)(sesuaikan total Servis ***)
/ip route
add dst-address=100.1.1.0/22 gateway=200.200.200.2 comment="Hotspot via RB5009"
add dst-address=200.1.1.0/23 gateway=200.200.200.2 comment="PPPoE via RB5009"

# ----------------------------------------------------------------------------------
## CONNTRACK TUNING (kecepatan & efisiensi)
/ip firewall connection tracking
set enabled=yes \
    tcp-established-timeout=15m \
    tcp-close-timeout=10s \
    tcp-fin-wait-timeout=10s \
    tcp-last-ack-timeout=10s \
    udp-timeout=10s \
    udp-stream-timeout=1m \
    icmp-timeout=10s

# Tambahkan interface-list=WAN untuk 7 ISP 
/interface list
add name=WAN

/interface list member
add interface=ether1 list=WAN
add interface=ether2 list=WAN
add interface=ether3 list=WAN
add interface=ether4 list=WAN
add interface=ether5 list=WAN
add interface=ether6 list=WAN
add interface=ether7 list=WAN

## FIREWALL RAW (drop sebelum conntrack)
/ip firewall raw
add chain=prerouting protocol=udp dst-port=53 in-interface-list=WAN action=drop comment="Block external DNS flood"

# Tambahkan rule ini jika internet masih terasa "patah-patah"
/ip firewall mangle
add action=change-mss chain=forward new-mss=clamp-to-pmtu passthrough=yes protocol=tcp tcp-flags=syn

