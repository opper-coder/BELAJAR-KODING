# 1. Membuat Tabel Routing (Wajib di v7 agar FIB aktif) [All ISP]
/routing table
add fib name=to-ISP1
add fib name=to-ISP2
add fib name=to-ISP3
add fib name=to-ISP4
add fib name=to-ISP5
add fib name=to-ISP6
add fib name=to-ISP7
# add fib name=to-ISP8

# 2. Konfigurasi IP Firewall NAT masquerade
/ip firewall nat
add action=masquerade chain=srcnat out-interface=ether1 comment="NAT ISP 1"
add action=masquerade chain=srcnat out-interface=ether2 comment="NAT ISP 2"
add action=masquerade chain=srcnat out-interface=ether3 comment="NAT ISP 3"
add action=masquerade chain=srcnat out-interface=ether4 comment="NAT ISP 4"
add action=masquerade chain=srcnat out-interface=ether5 comment="NAT ISP 5"
add action=masquerade chain=srcnat out-interface=ether6 comment="NAT ISP 6"
add action=masquerade chain=srcnat out-interface=ether7 comment="NAT ISP 7"
# add action=masquerade chain=srcnat out-interface=ether8 comment="NAT ISP 8"

# 3. Konfigurasi Mangle (citraweb IP beda)
# /ip firewall mangle
# A. Bypass Traffic Lokal (Agar akses ke router/lokal tidak kena Load Balance)[All Interface]
# add action=accept chain=prerouting dst-address=10.10.20.0/24 comment="Bypass ISP1"
# add action=accept chain=prerouting dst-address=10.10.30.0/24 comment="Bypass ISP2"
# add action=accept chain=prerouting dst-address=200.200.200.0/29 comment="Bypass Lokal"
# ----
# IP sama, atau manual IP ISP, ganti dengan ini:
# /ip firewall mangle
# add action=accept chain=prerouting dst-address-type=local comment="Bypass Traffic ke Router"
# add action=accept chain=prerouting dst-address=200.200.200.0/29 comment="Bypass Network Lokal" 

/ip firewall mangle
# Pindahkan/Buat rule ini di urutan paling atas. (index 0) kalau tidak jalan hapus bagian "place-before=0" (sudah jalan)
add action=accept chain=prerouting dst-address-type=local comment="Bypass Traffic ke Router" place-before=0
add action=accept chain=prerouting dst-address=200.200.200.0/29 comment="Bypass Network Lokal" place-before=1
add action=accept chain=prerouting dst-port=53 protocol=udp comment="Bypass DNS agar lancar" place-before=2
add action=accept chain=prerouting dst-port=53 protocol=tcp comment="Bypass DNS TCP" place-before=3

# B. Mark Connection dari Luar (Input) agar balik lewat jalur yang sama [All ISP]
/ip firewall mangle
add action=mark-connection chain=prerouting in-interface=ether1 connection-mark=no-mark new-connection-mark=ISP1_conn passthrough=yes
add action=mark-connection chain=prerouting in-interface=ether2 connection-mark=no-mark new-connection-mark=ISP2_conn passthrough=yes
add action=mark-connection chain=prerouting in-interface=ether3 connection-mark=no-mark new-connection-mark=ISP3_conn passthrough=yes
add action=mark-connection chain=prerouting in-interface=ether4 connection-mark=no-mark new-connection-mark=ISP4_conn passthrough=yes
add action=mark-connection chain=prerouting in-interface=ether5 connection-mark=no-mark new-connection-mark=ISP5_conn passthrough=yes
add action=mark-connection chain=prerouting in-interface=ether6 connection-mark=no-mark new-connection-mark=ISP6_conn passthrough=yes
add action=mark-connection chain=prerouting in-interface=ether7 connection-mark=no-mark new-connection-mark=ISP7_conn passthrough=yes
# add action=mark-connection chain=prerouting in-interface=ether8 connection-mark=no-mark new-connection-mark=ISP8_conn passthrough=yes

# C. PCC (Rasio 7:1 - Total Denominator 7)
/ip firewall mangle
# add chain=prerouting in-interface=ether3 connection-mark=ISP1_conn atau no-mark per-connection-classifier=both-addresses:3/0 \ # (citraweb)
add chain=prerouting in-interface=ether8 connection-mark=ISP1_conn per-connection-classifier=both-addresses:6/0 \
    dst-address-type=!local action=mark-connection new-connection-mark=ISP1_conn passthrough=yes comment="Stream-1"  
add chain=prerouting in-interface=ether8 connection-mark=ISP2_conn per-connection-classifier=both-addresses:6/1 \
    dst-address-type=!local action=mark-connection new-connection-mark=ISP2_conn passthrough=yes comment="Stream-2"  
add chain=prerouting in-interface=ether8 connection-mark=ISP3_conn per-connection-classifier=both-addresses:6/2 \
    dst-address-type=!local action=mark-connection new-connection-mark=ISP3_conn passthrough=yes comment="Stream-3"  
add chain=prerouting in-interface=ether8 connection-mark=ISP4_conn per-connection-classifier=both-addresses:6/3 \
    dst-address-type=!local action=mark-connection new-connection-mark=ISP4_conn passthrough=yes comment="Stream-4"  
add chain=prerouting in-interface=ether8 connection-mark=ISP5_conn per-connection-classifier=both-addresses:6/4 \
    dst-address-type=!local action=mark-connection new-connection-mark=ISP5_conn passthrough=yes comment="Stream-5"  
add chain=prerouting in-interface=ether8 connection-mark=ISP6_conn per-connection-classifier=both-addresses:6/5 \
    dst-address-type=!local action=mark-connection new-connection-mark=ISP6_conn passthrough=yes comment="Stream-6"  
add chain=prerouting in-interface=ether8 connection-mark=ISP7_conn per-connection-classifier=both-addresses:6/6 \
    dst-address-type=!local action=mark-connection new-connection-mark=ISP7_conn passthrough=yes comment="Stream-7"  
# add chain=prerouting in-interface=ether8 connection-mark=no-mark per-connection-classifier=both-addresses:7/7 \
#     dst-address-type=!local action=mark-connection new-connection-mark=ISP2_conn passthrough=yes comment="Stream-8"  

# D. Mark Routing prerouting (Mengarahkan traffic ke tabel routing yang dibuat di langkah 1) [All ISP]
/ip firewall mangle
add chain=prerouting in-interface=ether8 connection-mark=ISP1_conn \
    action=mark-routing new-routing-mark=to-ISP1 passthrough=no 
add chain=prerouting in-interface=ether8 connection-mark=ISP2_conn \
    action=mark-routing new-routing-mark=to-ISP2 passthrough=no 
add chain=prerouting in-interface=ether8 connection-mark=ISP3_conn \
    action=mark-routing new-routing-mark=to-ISP3 passthrough=no 
add chain=prerouting in-interface=ether8 connection-mark=ISP4_conn \
    action=mark-routing new-routing-mark=to-ISP4 passthrough=no 
add chain=prerouting in-interface=ether8 connection-mark=ISP5_conn \
    action=mark-routing new-routing-mark=to-ISP5 passthrough=no 
add chain=prerouting in-interface=ether8 connection-mark=ISP6_conn \
    action=mark-routing new-routing-mark=to-ISP6 passthrough=no 
add chain=prerouting in-interface=ether8 connection-mark=ISP7_conn \
    action=mark-routing new-routing-mark=to-ISP7 passthrough=no 
# add chain=prerouting in-interface=ether8 connection-mark=ISP8_conn \
#     action=mark-routing new-routing-mark=to-ISP8 passthrough=no 

# E. Mark Routing Output (Untuk traffic dari router itu sendiri) [All ISP]
/ip firewall mangle
add chain=output connection-mark=ISP1_conn action=mark-routing new-routing-mark=to-ISP1 passthrough=no
add chain=output connection-mark=ISP2_conn action=mark-routing new-routing-mark=to-ISP2 passthrough=no
add chain=output connection-mark=ISP3_conn action=mark-routing new-routing-mark=to-ISP3 passthrough=no
add chain=output connection-mark=ISP4_conn action=mark-routing new-routing-mark=to-ISP4 passthrough=no
add chain=output connection-mark=ISP5_conn action=mark-routing new-routing-mark=to-ISP5 passthrough=no
add chain=output connection-mark=ISP6_conn action=mark-routing new-routing-mark=to-ISP6 passthrough=no
add chain=output connection-mark=ISP7_conn action=mark-routing new-routing-mark=to-ISP7 passthrough=no
# add chain=output connection-mark=ISP8_conn action=mark-routing new-routing-mark=to-ISP8 passthrough=no

# 4. Konfigurasi Jalur Gateway (Routing)
# Sesuai dengan IP Gateway ISP Anda [All ISP]
/ip route
add dst-address=0.0.0.0/0 gateway=192.168.1.1%ether1 routing-table=to-ISP1 
add dst-address=0.0.0.0/0 gateway=192.168.1.1%ether2 routing-table=to-ISP2 
add dst-address=0.0.0.0/0 gateway=192.168.1.1%ether3 routing-table=to-ISP3 
add dst-address=0.0.0.0/0 gateway=192.168.1.1%ether4 routing-table=to-ISP4 
add dst-address=0.0.0.0/0 gateway=192.168.1.1%ether5 routing-table=to-ISP5 
add dst-address=0.0.0.0/0 gateway=192.168.3.1%ether6 routing-table=to-ISP6 
add dst-address=0.0.0.0/0 gateway=192.168.1.1%ether7 routing-table=to-ISP7 
# add dst-address=0.0.0.0/0 gateway=192.168.1.1%ether8 routing-table=to-ISP8 check-gateway=ping

